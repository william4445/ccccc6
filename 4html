<script>
const TOTAL = 11;
let current = 1;
const visited = new Set([1]);

// Build dots
const dotC = document.getElementById('dot-container');
for(let i=1;i<=TOTAL;i++){
  const d = document.createElement('div');
  d.className = 'dot' + (i===1?' active':'');
  d.title = 'Diapositiva ' + i;
  d.onclick = () => goToSlide(i);
  dotC.appendChild(d);
}

function goToSlide(n){
  if(n<1||n>TOTAL) return;
  document.getElementById('slide-'+current).classList.remove('active');
  current = n;
  visited.add(n);
  document.getElementById('slide-'+current).classList.add('active');
  updateUI();
}
function nextSlide(){ goToSlide(current+1); }
function prevSlide(){ goToSlide(current-1); }

function updateUI(){
  document.getElementById('slide-counter').textContent = `Diapositiva ${current} / ${TOTAL}`;
  document.getElementById('progress-fill').style.width = ((current/TOTAL)*100) + '%';
  document.getElementById('btn-prev').disabled = current===1;
  document.getElementById('btn-next').disabled = current===TOTAL;
  document.querySelectorAll('.dot').forEach((d,i)=>{
    d.className = 'dot' + (i+1===current?' active':(visited.has(i+1)?' visited':''));
  });
}

/* === QUIZ: Single Choice === */
function answerQ(qid, btn, isCorrect){
  const container = document.getElementById(qid+'-opts');
  if(container.dataset.answered) return;
  container.dataset.answered = '1';
  container.querySelectorAll('.option-btn').forEach(b=>{
    b.classList.add('disabled');
    if(b.dataset.correct==='true') b.classList.add('correct');
  });
  if(!isCorrect) btn.classList.add('incorrect');
  const fb = document.getElementById(qid+'-feedback');
  fb.className = 'feedback-area show ' + (isCorrect?'success':'error');
  fb.innerHTML = isCorrect
    ? '🎉 ¡Correcto! Word se usa para crear y editar documentos de texto.'
    : '❌ Intenta recordar la función principal de cada herramienta. Word = Documentos.';
}

/* === QUIZ: Multi-select === */
function toggleMulti(el, qid){
  const fb = document.getElementById(qid+'-feedback');
  if(fb.dataset.checked) return;
  el.classList.toggle('selected');
  if(el.classList.contains('selected')) el.querySelector('.checkbox').innerHTML='✓';
  else el.querySelector('.checkbox').innerHTML='';
}

function checkMulti(qid){
  const fb = document.getElementById(qid+'-feedback');
  if(fb.dataset.checked) return;
  fb.dataset.checked = '1';
  const opts = document.querySelectorAll('#'+qid+'-options .multi-option');
  let score=0, total=0;
  opts.forEach(o=>{
    o.classList.remove('selected');
    const correct = o.dataset.correct==='true';
    const selected = o.classList.contains('selected') || o.querySelector('.checkbox').innerHTML==='✓';
    if(correct) total++;
    if(correct && selected){ o.classList.add('correct'); o.querySelector('.checkbox').innerHTML='✓'; score++; }
    else if(!correct && selected){ o.classList.add('incorrect'); o.querySelector('.checkbox').innerHTML='✗'; }
    else if(correct && !selected){ o.classList.add('correct'); o.querySelector('.checkbox').innerHTML='✓'; }
    o.onclick=null;
  });
  fb.className = 'feedback-area show ' + (score===total?'success':'error');
  fb.innerHTML = score===total
    ? '🌟 ¡Muy bien! Reconoces perfectamente las herramientas TIC: Computadora, Internet y Proyector.'
    : `⚠️ Revisaste ${score} de ${total} correctas. Las TIC usan tecnología digital: Computadora, Internet y Proyector.`;
}

/* === DRAG & DROP === */
let dragging = null;
const matches = {};

function dragStart(e, id){ dragging = id; e.dataTransfer.effectAllowed='move'; }
function dragOver(e){ e.preventDefault(); e.currentTarget.classList.add('drag-over'); }

function drop(e, zone){
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  if(!dragging) return;
  matches[zone] = dragging;
  const zoneEl = e.currentTarget;
  const names = {word:'📝 Word', excel:'📊 Excel', ppt:'🎞️ PowerPoint'};
  const colors = {word:'#2B579A', excel:'#217346', ppt:'#B7472A'};
  zoneEl.innerHTML = `<span style="color:${colors[dragging]};font-weight:800">${names[dragging]}</span>`;
  dragging = null;
}

function checkMatch(){
  const expects = {docs:'word', calcs:'excel', pres:'ppt'};
  let correct = 0;
  Object.entries(expects).forEach(([zone, exp])=>{
    const el = document.getElementById('drop-'+zone);
    if(matches[zone]===exp){ el.classList.add('matched'); correct++; }
    else if(matches[zone]) el.classList.add('wrong-match');
  });
  const fb = document.getElementById('match-feedback');
  fb.className = 'match-feedback show ' + (correct===3?'success':'partial');
  fb.innerHTML = correct===3
    ? '🏆 ¡Excelente! Emparejaste correctamente todas las herramientas con sus funciones.'
    : `⚠️ ${correct}/3 correctas. Recuerda: Word → Documentos, Excel → Cálculos, PowerPoint → Presentaciones.`;
}

/* === REFLECTION === */
function submitReflection(){
  const r1 = document.getElementById('ref1').value.trim();
  const r2 = document.getElementById('ref2').value.trim();
  if(!r1||!r2){ alert('Por favor responde ambas preguntas para continuar.'); return; }
  document.getElementById('final-msg').classList.add('show');
  document.querySelector('.btn-submit-reflection').disabled = true;
  document.querySelector('.btn-submit-reflection').style.opacity = '0.6';
}

updateUI();
</script>
