<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Introducción a las Herramientas Microsoft</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --ms-blue: #0078D4;
    --ms-dark: #004578;
    --ms-light: #EFF6FC;
    --ms-green: #107C10;
    --ms-orange: #D83B01;
    --ms-yellow: #FFB900;
    --ms-purple: #5C2D91;
    --word-blue: #2B579A;
    --excel-green: #217346;
    --ppt-red: #B7472A;
    --bg: #f0f4ff;
    --card: #ffffff;
    --text: #1a1a2e;
    --text-light: #555;
    --radius: 18px;
    --shadow: 0 8px 32px rgba(0,120,212,0.13);
    --shadow-hover: 0 16px 48px rgba(0,120,212,0.22);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--bg);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* PROGRESS BAR */
  #progress-bar {
    position: fixed; top:0; left:0; width:100%; height:5px; z-index:1000;
    background: rgba(0,120,212,0.15);
  }
  #progress-fill {
    height:100%; background: linear-gradient(90deg, var(--ms-blue), var(--ms-yellow));
    transition: width 0.5s cubic-bezier(.4,0,.2,1);
    border-radius: 0 3px 3px 0;
  }

  /* HEADER */
  .h5p-header {
    background: linear-gradient(135deg, #0052a3 0%, #0078D4 50%, #00a4ef 100%);
    color: #fff;
    padding: 14px 32px;
    display: flex; align-items: center; justify-content: space-between;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    position: sticky; top:5px; z-index:999;
  }
  .h5p-header .logo {
    display: flex; align-items: center; gap: 10px;
  }
  .h5p-header .logo svg { width:34px; height:34px; }
  .h5p-header h1 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.1rem; font-weight:700; letter-spacing:-0.3px;
  }
  .h5p-header .slide-counter {
    background: rgba(255,255,255,0.2);
    border-radius: 20px; padding: 5px 16px;
    font-size: 0.85rem; font-weight:700;
  }

  /* MAIN CONTAINER */
  .h5p-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 32px 20px 100px;
  }

  /* SLIDE */
  .slide {
    display: none;
    animation: slideIn 0.5s cubic-bezier(.4,0,.2,1);
  }
  .slide.active { display: block; }
  @keyframes slideIn {
    from { opacity:0; transform: translateY(24px) scale(0.98); }
    to   { opacity:1; transform: translateY(0) scale(1); }
  }

  /* CARD BASE */
  .card {
    background: var(--card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    margin-bottom: 24px;
  }

  /* ===== SLIDE 1: PORTADA ===== */
  .portada {
    background: linear-gradient(145deg, #0052a3 0%, #0078D4 40%, #00a4ef 100%);
    min-height: 420px;
    display: flex; flex-direction:column; align-items:center; justify-content:center;
    text-align:center; padding: 48px 32px; color:#fff; position:relative; overflow:hidden;
  }
  .portada::before {
    content:''; position:absolute; inset:0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Ccircle cx='30' cy='30' r='28'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") repeat;
  }
  .portada .floating-icons {
    display: flex; gap: 32px; margin-bottom: 32px; position:relative; z-index:1;
  }
  .app-icon {
    width: 72px; height:72px; border-radius: 18px;
    display:flex; align-items:center; justify-content:center;
    font-size: 2rem; font-weight:900;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    animation: floatIcon 3s ease-in-out infinite;
    cursor:default;
  }
  .app-icon.word  { background: var(--word-blue); animation-delay:0s; }
  .app-icon.excel { background: var(--excel-green); animation-delay:0.5s; }
  .app-icon.ppt   { background: var(--ppt-red); animation-delay:1s; }
  @keyframes floatIcon {
    0%,100% { transform: translateY(0) rotate(-2deg); }
    50%      { transform: translateY(-12px) rotate(2deg); }
  }
  .portada h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 2.2rem; font-weight:800; line-height:1.2;
    margin-bottom: 12px; position:relative; z-index:1;
    text-shadow: 0 2px 12px rgba(0,0,0,0.2);
  }
  .portada .subtitle {
    font-size: 1.1rem; opacity:0.9; margin-bottom: 8px; position:relative; z-index:1;
  }
  .portada .quote {
    font-style: italic; font-size: 0.95rem;
    background: rgba(255,255,255,0.15); border-radius: 12px;
    padding: 12px 24px; margin: 20px 0; position:relative; z-index:1;
    border-left: 4px solid var(--ms-yellow);
  }
  .btn-start {
    display: inline-block; margin-top: 12px;
    background: var(--ms-yellow); color: #1a1a2e;
    padding: 14px 36px; border-radius: 50px;
    font-weight: 800; font-size: 1.05rem;
    border: none; cursor: pointer;
    box-shadow: 0 6px 20px rgba(255,185,0,0.4);
    transition: all 0.2s; position:relative; z-index:1;
    letter-spacing: 0.3px;
  }
  .btn-start:hover { transform:translateY(-3px) scale(1.03); box-shadow: 0 10px 28px rgba(255,185,0,0.55); }
  .portada .meta { font-size: 0.8rem; opacity:0.7; margin-top: 20px; position:relative; z-index:1; }

  /* ===== CONCEPT SLIDE ===== */
  .concept-header {
    background: linear-gradient(135deg, var(--ms-blue), var(--ms-dark));
    color:#fff; padding: 24px 32px;
  }
  .concept-header .badge {
    display: inline-block; background: rgba(255,255,255,0.2);
    border-radius: 20px; padding: 4px 14px; font-size:0.78rem;
    font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:8px;
  }
  .concept-header h2 { font-family:'Poppins',sans-serif; font-size:1.6rem; font-weight:800; }
  .concept-body { padding: 28px 32px; }
  .concept-body p { color: var(--text); line-height:1.7; font-size:1rem; margin-bottom:16px; }
  .concept-list {
    list-style: none; display: flex; flex-direction:column; gap:10px;
  }
  .concept-list li {
    display: flex; align-items:center; gap: 12px;
    background: var(--ms-light); border-radius: 12px; padding: 12px 16px;
    color: var(--text); font-weight:600;
    border-left: 4px solid var(--ms-blue);
    transition: all 0.2s;
    animation: fadeUp 0.4s ease forwards; opacity:0;
  }
  .concept-list li:nth-child(1){animation-delay:.1s}
  .concept-list li:nth-child(2){animation-delay:.2s}
  .concept-list li:nth-child(3){animation-delay:.3s}
  .concept-list li:nth-child(4){animation-delay:.4s}
  .concept-list li:hover { background: #dbeeff; transform:translateX(6px); }
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(16px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .concept-list li .icon { font-size:1.3rem; min-width:28px; }
  .feedback-box {
    margin-top: 20px; padding: 16px 20px;
    background: #f0faf0; border-radius: 12px;
    border-left: 4px solid var(--ms-green);
    color: var(--ms-green); font-weight:600; font-size:0.95rem;
  }

  /* ===== QUIZ SLIDE ===== */
  .quiz-header {
    background: linear-gradient(135deg, #5C2D91, #8661C5);
    color:#fff; padding: 24px 32px;
  }
  .quiz-header h2 { font-family:'Poppins',sans-serif; font-size:1.5rem; font-weight:800; }
  .quiz-body { padding: 28px 32px; }
  .quiz-instruction {
    background: #f5f0ff; border-radius: 12px; padding: 14px 18px;
    color: #5C2D91; font-weight:700; margin-bottom: 22px;
    border-left: 4px solid #8661C5;
  }
  .options-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
    margin-bottom: 20px;
  }
  .option-btn {
    display: flex; align-items: center; gap: 12px;
    background: #fff; border: 2.5px solid #ddd;
    border-radius: 14px; padding: 14px 18px;
    cursor: pointer; font-family: 'Nunito', sans-serif;
    font-size: 0.98rem; font-weight:700; color: var(--text);
    transition: all 0.2s; text-align: left;
  }
  .option-btn .opt-icon { font-size:1.4rem; }
  .option-btn:hover:not(.disabled) {
    border-color: var(--ms-blue); background: var(--ms-light);
    transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,120,212,0.15);
  }
  .option-btn.correct { border-color: var(--ms-green); background: #f0faf0; color: var(--ms-green); }
  .option-btn.incorrect { border-color: var(--ms-orange); background: #fff4f0; color: var(--ms-orange); }
  .option-btn.disabled { cursor: default; }
  .option-btn.selected-wrong { border-color: var(--ms-orange); background: #fff4f0; }
  .feedback-area {
    min-height: 56px; border-radius: 12px; padding: 14px 18px;
    font-weight:700; font-size:0.95rem; display:flex; align-items:center; gap:10px;
    opacity:0; transition: opacity 0.3s;
  }
  .feedback-area.show { opacity:1; }
  .feedback-area.success { background: #f0faf0; color: var(--ms-green); border: 2px solid #a3d9a5; }
  .feedback-area.error   { background: #fff4f0; color: var(--ms-orange); border: 2px solid #f5b8a0; }
  .quiz-score {
    display: flex; gap: 8px; align-items:center;
    font-size:0.85rem; color: var(--text-light); margin-top: 10px;
  }
  .score-dot { width:10px; height:10px; border-radius:50%; background:#ddd; }
  .score-dot.correct { background: var(--ms-green); }
  .score-dot.incorrect { background: var(--ms-orange); }

  /* ===== TOOLS GRID ===== */
  .tools-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px;
    padding: 28px 32px;
  }
  .tool-card {
    border-radius: 16px; padding: 24px 16px; text-align:center;
    cursor: default;
    transition: all 0.25s;
    position: relative; overflow:hidden;
  }
  .tool-card::after {
    content:''; position:absolute; inset:0; opacity:0;
    background: radial-gradient(circle at 50% 0%, rgba(255,255,255,0.25), transparent 70%);
    transition: opacity 0.3s;
  }
  .tool-card:hover { transform:translateY(-6px) scale(1.03); box-shadow: var(--shadow-hover); }
  .tool-card:hover::after { opacity:1; }
  .tool-card.word-card  { background: linear-gradient(145deg, #2B579A, #1e3f7a); color:#fff; }
  .tool-card.excel-card { background: linear-gradient(145deg, #217346, #165430); color:#fff; }
  .tool-card.ppt-card   { background: linear-gradient(145deg, #B7472A, #8a2a10); color:#fff; }
  .tool-card .tool-icon { font-size:2.8rem; margin-bottom:10px; display:block; }
  .tool-card h3 { font-family:'Poppins',sans-serif; font-size:1.2rem; font-weight:800; margin-bottom:8px; }
  .tool-card ul { list-style:none; font-size:0.88rem; opacity:0.9; line-height:1.8; text-align:left; }
  .tool-card ul li::before { content: '→ '; opacity:0.7; }

  /* ===== DRAG-AND-DROP MATCH ===== */
  .match-container { padding: 28px 32px; }
  .match-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .match-col h4 { font-weight:800; color: var(--text); margin-bottom:14px; font-size:0.9rem; text-transform:uppercase; letter-spacing:0.8px; }
  .draggable-item {
    background: linear-gradient(135deg, #0078D4, #005ea2);
    color: #fff; border-radius: 12px; padding: 12px 18px;
    margin-bottom: 10px; cursor: grab; font-weight:700;
    display:flex; align-items:center; gap:10px;
    transition: all 0.2s; user-select:none;
    box-shadow: 0 4px 12px rgba(0,120,212,0.3);
  }
  .draggable-item:hover { transform: scale(1.03); box-shadow: 0 6px 20px rgba(0,120,212,0.4); }
  .draggable-item:active { cursor: grabbing; transform: scale(0.97); }
  .drop-zone {
    background: #f8f9ff; border: 2.5px dashed #c0cfe8;
    border-radius: 12px; padding: 14px 18px; min-height: 54px;
    margin-bottom: 10px; display:flex; align-items:center; gap:10px;
    color: #8899bb; font-weight:600; font-size:0.95rem;
    transition: all 0.2s;
  }
  .drop-zone.drag-over { border-color: var(--ms-blue); background: var(--ms-light); }
  .drop-zone.matched { border-color: var(--ms-green); background: #f0faf0; color: var(--ms-green); }
  .drop-zone.wrong-match { border-color: var(--ms-orange); background: #fff4f0; }
  .match-label { font-size:0.85rem; opacity:0.7; }
  .match-feedback {
    margin-top: 20px; padding: 14px 18px; border-radius: 12px;
    font-weight:700; font-size:0.95rem; display:none;
  }
  .match-feedback.show { display:flex; align-items:center; gap:10px; }
  .match-feedback.success { background: #f0faf0; color: var(--ms-green); border: 2px solid #a3d9a5; }
  .match-feedback.partial { background: #fffbe0; color: #b58900; border: 2px solid #f5d78a; }
  .btn-check-match {
    margin-top: 18px; background: var(--ms-blue); color:#fff;
    border: none; border-radius: 12px; padding: 13px 32px;
    font-family:'Nunito',sans-serif; font-size:1rem; font-weight:800; cursor:pointer;
    transition: all 0.2s; box-shadow: 0 4px 14px rgba(0,120,212,0.3);
  }
  .btn-check-match:hover { background: var(--ms-dark); transform:translateY(-2px); }

  /* ===== REFLECTION SLIDE ===== */
  .reflection-body { padding: 28px 32px; }
  .reflection-q {
    background: linear-gradient(135deg, #f5f0ff, #ebe3ff);
    border-left: 5px solid var(--ms-purple);
    border-radius: 12px; padding: 18px 20px; margin-bottom: 18px;
  }
  .reflection-q p { font-weight:700; color: var(--ms-purple); margin-bottom:10px; font-size:1rem; }
  .reflection-q textarea {
    width:100%; min-height: 80px; border: 2px solid #ddd;
    border-radius: 10px; padding: 10px 14px;
    font-family:'Nunito',sans-serif; font-size:0.95rem;
    resize: vertical; color: var(--text);
    transition: border-color 0.2s;
  }
  .reflection-q textarea:focus { outline:none; border-color: var(--ms-purple); }
  .btn-submit-reflection {
    background: linear-gradient(135deg, var(--ms-green), #0a5e0a);
    color:#fff; border:none; border-radius: 12px; padding: 13px 32px;
    font-family:'Nunito',sans-serif; font-size:1rem; font-weight:800; cursor:pointer;
    transition: all 0.2s; box-shadow: 0 4px 14px rgba(16,124,16,0.3);
  }
  .btn-submit-reflection:hover { transform:translateY(-2px); box-shadow: 0 8px 20px rgba(16,124,16,0.4); }
  .final-message {
    text-align:center; margin-top: 28px; padding: 28px;
    background: linear-gradient(135deg, var(--ms-blue), var(--ms-dark));
    border-radius: 16px; color:#fff; display:none;
  }
  .final-message.show { display:block; animation: fadeUp 0.5s ease; }
  .final-message .big-emoji { font-size: 3rem; margin-bottom: 12px; }
  .final-message h3 { font-family:'Poppins',sans-serif; font-size:1.4rem; font-weight:800; margin-bottom:8px; }
  .final-message p { opacity:0.9; line-height:1.6; }

  /* ===== NAVIGATION ===== */
  .nav-bar {
    position: fixed; bottom: 0; left:0; right:0;
    background: #fff; border-top: 2px solid #e8f0fe;
    padding: 14px 32px; display:flex; align-items:center; justify-content:space-between;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.08); z-index:998;
  }
  .nav-btn {
    display:flex; align-items:center; gap:8px;
    background: var(--ms-blue); color:#fff;
    border:none; border-radius: 12px; padding: 11px 24px;
    font-family:'Nunito',sans-serif; font-size:0.95rem; font-weight:800;
    cursor: pointer; transition: all 0.2s;
    box-shadow: 0 4px 14px rgba(0,120,212,0.25);
  }
  .nav-btn:hover { background: var(--ms-dark); transform:translateY(-2px); }
  .nav-btn:disabled { background: #ccc; cursor:default; transform:none; box-shadow:none; }
  .nav-btn.prev { background: #f0f4ff; color: var(--ms-blue); border: 2px solid var(--ms-blue); box-shadow:none; }
  .nav-btn.prev:hover { background: var(--ms-light); }
  .slide-dots {
    display:flex; gap:8px; align-items:center;
  }
  .dot {
    width: 10px; height:10px; border-radius:50%;
    background: #ddd; transition: all 0.3s; cursor:pointer;
  }
  .dot.active { background: var(--ms-blue); transform:scale(1.4); }
  .dot.visited { background: #a0c4f1; }

  /* ===== STATS WIDGET ===== */
  .stats-bar {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 16px;
    margin-bottom: 24px;
  }
  .stat-card {
    background:#fff; border-radius:14px; padding: 18px;
    text-align:center; box-shadow: var(--shadow);
    border-top: 4px solid var(--ms-blue);
    animation: fadeUp 0.4s ease forwards; opacity:0;
  }
  .stat-card:nth-child(1){animation-delay:.1s;border-color:var(--ms-blue)}
  .stat-card:nth-child(2){animation-delay:.2s;border-color:var(--ms-green)}
  .stat-card:nth-child(3){animation-delay:.3s;border-color:var(--ms-purple)}
  .stat-card .num {
    font-family:'Poppins',sans-serif; font-size:2rem; font-weight:900;
    color: var(--ms-blue);
  }
  .stat-card:nth-child(2) .num { color: var(--ms-green); }
  .stat-card:nth-child(3) .num { color: var(--ms-purple); }
  .stat-card .label { font-size:0.82rem; color:var(--text-light); font-weight:700; margin-top:4px; }

  /* MULTI-SELECT */
  .multi-option {
    display:flex; align-items:center; gap:12px;
    background:#fff; border: 2.5px solid #ddd;
    border-radius: 14px; padding: 13px 18px;
    margin-bottom: 12px; cursor:pointer;
    font-weight:700; color: var(--text); font-size:0.98rem;
    transition: all 0.2s; user-select:none;
  }
  .multi-option:hover { border-color: var(--ms-purple); background: #f5f0ff; }
  .multi-option.selected { border-color: var(--ms-purple); background: #f5f0ff; color: var(--ms-purple); }
  .multi-option.correct { border-color: var(--ms-green); background: #f0faf0; color: var(--ms-green); }
  .multi-option.incorrect { border-color: var(--ms-orange); background: #fff4f0; color: var(--ms-orange); }
  .multi-option .checkbox {
    width: 22px; height:22px; border-radius:6px; border: 2.5px solid #bbb;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
    transition: all 0.2s; font-size:0.9rem;
  }
  .multi-option.selected .checkbox { background: var(--ms-purple); border-color: var(--ms-purple); color:#fff; }
  .multi-option.correct .checkbox  { background: var(--ms-green); border-color: var(--ms-green); color:#fff; }
  .multi-option.incorrect .checkbox { background: var(--ms-orange); border-color: var(--ms-orange); color:#fff; }
  .btn-check {
    margin-top: 8px; background: var(--ms-purple); color:#fff;
    border:none; border-radius:12px; padding: 12px 28px;
    font-family:'Nunito',sans-serif; font-size:1rem; font-weight:800; cursor:pointer;
    transition: all 0.2s; box-shadow: 0 4px 14px rgba(92,45,145,0.3);
  }
  .btn-check:hover { background: #4a1f7e; transform:translateY(-2px); }

  /* RESPONSIVE */
  @media(max-width:620px){
    .options-grid { grid-template-columns:1fr; }
    .tools-grid { grid-template-columns:1fr; }
    .match-cols { grid-template-columns:1fr; }
    .stats-bar { grid-template-columns:1fr; }
    .portada h2 { font-size:1.6rem; }
    .h5p-container { padding: 20px 12px 100px; }
    .concept-body, .quiz-body, .match-container, .reflection-body { padding: 20px; }
  }
</style>
</head>
<body>

<!-- PROGRESS BAR -->
<div id="progress-bar"><div id="progress-fill" style="width:9.09%"></div></div>

<!-- HEADER -->
<div class="h5p-header">
  <div class="logo">
    <svg viewBox="0 0 24 24" fill="white"><path d="M3 3h8v8H3zm10 0h8v8h-8zM3 13h8v8H3zm10 0h8v8h-8z"/></svg>
    <h1>Herramientas Microsoft · H5P</h1>
  </div>
  <div class="slide-counter" id="slide-counter">Diapositiva 1 / 11</div>
</div>

<!-- MAIN -->
<div class="h5p-container">

  <!-- SLIDE 1: PORTADA -->
  <div class="slide active" id="slide-1">
    <div class="card">
      <div class="portada">
        <div class="floating-icons">
          <div class="app-icon word" style="background:#fff;padding:6px;"><img src="data:image/svg+xml;base64," style="width:52px;height:52px;object-fit:contain;" /></div>
          <div class="app-icon excel" style="background:#fff;padding:6px;"><img src="data:image/svg+xml;base64," style="width:52px;height:52px;object-fit:contain;" /></div>
          <div class="app-icon ppt" style="background:#fff;padding:4px;"><img src="data:image/jpeg;base64," style="width:60px;height:60px;object-fit:contain;border-radius:10px;" /></div>
        </div>
